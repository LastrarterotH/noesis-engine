  "script": [
    { "wait": 0.8 },
    { "caption": "PERSÉFONE Y DEMÉTER", "style": "title" },
    { "wait": 2.4 },
    { "caption": "", "style": "title" },
    { "caption": "Antes de las estaciones, la tierra florecía todo el año." },
    { "wait": 4.2 },
    { "say": "perse", "text": "Madre, jamás había visto tantas flores juntas.", "duration": 3.4 },
    { "wait": 3.6 },
    { "say": "deme", "text": "Donde tú caminas, hija mía, la vida te sigue.", "duration": 3.4 },
    { "wait": 4.0 },

