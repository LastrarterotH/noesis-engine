    { "type": "learner", "id": "observador", "x": 852, "y": 366, "scale": 4.8, "hero": true, "body": "#4f8a5e", "name": "Observador", "behavior": null, "_alpha": 0 }
  ],
  "script": [
    { "wait": 0.8 },
    { "caption": "EL GATO DE SCHRÖDINGER", "style": "title" },
    { "wait": 2.2 },
    { "caption": "En el mundo cuántico algo puede estar en varios estados a la vez, hasta que se mide. A eso se le llama superposición." },
    { "wait": 4.6 },
    { "say": "erwin", "text": "¿Qué ocurre si llevo esa idea al mundo de todos los días?", "duration": 3.6 },
    { "wait": 4.0 },
    { "caption": "", "style": "title" },

    { "caption": "El asistente prepara una caja sellada, con un mecanismo dentro." },
    { "wait": 2.6 },
    { "focus": [440, 290], "color": "#F4AC1D", "radius": 56 },
    { "say": "asistente", "text": "Dentro hay un átomo radiactivo.", "duration": 2.6 },
    { "wait": 3.0 },
    { "say": "erwin", "text": "¿Y si se desintegra?", "duration": 2.2 },
    { "wait": 2.6 },
    { "say": "asistente", "text": "El contador lo detecta.", "duration": 2.4 },
    { "tone": 880, "dur": 0.12 },
    { "wait": 2.8 },
    { "say": "erwin", "text": "¿Y entonces?", "duration": 1.8 },
    { "wait": 2.2 },
    { "say": "asistente", "text": "El martillo rompe el frasco.", "duration": 2.6 },
    { "tone": 520, "dur": 0.16 },
    { "wait": 2.8 },
    { "say": "erwin", "text": "¿Y entonces?", "duration": 1.8 },
    { "wait": 2.0 },
    { "say": "asistente", "text": "El veneno se libera.", "duration": 2.4 },
    { "wait": 2.8 },
    { "caption": "El átomo tiene un 50% de desintegrarse en una hora. La suerte del gato queda atada a ese azar." },
    { "wait": 4.4 },
    { "focus": [440, 290], "off": true },
    { "wait": 0.5 },

    { "caption": "Entra el invitado. No sabe nada de esto." },
    { "say": "asistente", "text": "Ven, no hay nada que temer.", "duration": 2.4 },
    { "wait": 1.0 },
    { "path": "gato_vivo", "points": [ [610, 392], [560, 392], [512, 388], [482, 372], [458, 350], [440, 337] ], "duration": 3.6, "easing": "easeInOut" },
    { "waitFor": "arrive:gato_vivo" },
    { "do": "var c = world.props.find(function (p) { return p.id === 'gato_vivo'; }); if (c) c.pose = 'curl';" },
    { "wait": 0.6 },
    { "say": "erwin", "text": "Para él, es una siesta. Para nosotros, una paradoja.", "duration": 3.4 },
    { "wait": 3.6 },

    { "caption": "El asistente sella la caja." },
    { "tween": "caja_frente.glass", "to": 0, "duration": 1.0, "easing": "easeInOut" },
    { "tone": 174, "dur": 0.5 },
    { "camera": { "shake": 4 } },
    { "wait": 1.8 },

    { "music": { "volume": 0.4, "duration": 2 } },
    { "caption": "Ahora nadie puede mirar dentro. Solo corre el tiempo." },
    { "tween": "ambient.darkness", "to": 0.6, "duration": 2.4, "easing": "easeInOut" },
    { "tone": 1320, "dur": 0.06 },
    { "wait": 0.8 },
    { "tone": 1320, "dur": 0.06 },
    { "wait": 0.8 },
    { "tone": 1320, "dur": 0.06 },
    { "wait": 1.0 },
    { "caption": "El átomo no se ha desintegrado ni ha dejado de hacerlo. Está en superposición: las dos cosas a la vez." },
    { "wait": 4.6 },

    { "caption": "" },
    { "camera": { "to": [440, 312], "zoom": 1.3 } },
    { "focus": [440, 312], "color": "#5b8def", "radius": 116 },
    { "tween": "caja_frente.glass", "to": 0.82, "duration": 1.6, "easing": "easeInOut" },
    { "caption": "Si el formalismo vale también para lo grande, describe al gato igual que al átomo." },
    { "tone": 392, "dur": 0.4 },
    { "tween": "gato_vivo.alpha", "to": 0.55, "duration": 1.4 },
    { "wait": 3.0 },
    { "tone": 880, "dur": 0.1 },
    { "wait": 0.4 },
    { "tone": 520, "dur": 0.12 },
    { "wait": 0.4 },
    { "tone": 300, "dur": 0.32 },
    { "particles": { "x": 440, "y": 290, "color": "#c44a3e", "count": 14, "speed": 64, "duration": 0.8, "spread": 6.28, "size": 2 } },
    { "tween": "gato_muerto.alpha", "to": 0.55, "duration": 1.2 },
    { "wait": 1.8 },
    { "music": "stinger" },
    { "caption": "Un gato vivo. Un gato muerto. Al mismo tiempo." },
    { "wait": 3.8 },
    { "say": "asistente", "text": "Eso es imposible.", "duration": 2.2 },
    { "wait": 2.6 },
    { "say": "erwin", "text": "Precisamente. Ese es el punto.", "duration": 2.8 },
    { "wait": 3.2 },
    { "music": { "volume": 0.9, "duration": 2.5 } },
    { "caption": "Schrödinger no defendía esto. Mostraba el absurdo de estirar la cuántica al mundo grande sin más." },
    { "wait": 4.6 },

    { "caption": "Queda la pregunta de fondo: cuándo una posibilidad se vuelve un hecho." },
    { "wait": 1.0 },
    { "appear": "observador", "duration": 0.8 },
    { "wait": 0.6 },
    { "walk": "observador", "to": [560, 366] },
    { "waitFor": "arrive:observador" },
    { "wait": 0.5 },
    { "caption": "A eso se le llama el problema de la medición." },
    { "wait": 3.4 },

    { "caption": "El observador mira." },
    { "tween": "caja_frente.wheel", "to": 6.283, "duration": 2.0, "easing": "easeInOut" },
    { "sweep": [392, 176], "dur": 1.6 },
    { "wait": 1.2 },
    { "music": { "volume": 0.2, "duration": 2 } },
    { "caption": "Las dos realidades se desvanecen. Como humo." },
    { "focus": [440, 312], "off": true },
    { "tween": "gato_vivo.alpha", "to": 0, "duration": 1.4 },
    { "tween": "gato_muerto.alpha", "to": 0, "duration": 1.4 },
    { "tween": "caja_frente.glass", "to": 0, "duration": 1.4 },
    { "camera": { "reset": true } },
    { "wait": 1.8 },

    { "do": "world.props.forEach(function (p) { if (p.type === 'lamp' || p.type === 'candle') p.light = false; });" },
    { "tween": "ambient.darkness", "to": 1, "duration": 1.8, "easing": "easeInOutCubic" },
    { "tone": 130, "dur": 0.9 },
    { "wait": 2.0 },
    { "music": { "volume": 0, "duration": 0.3 } },
    { "caption": "Justo antes de saber cuál queda, todo es oscuridad." },
    { "wait": 3.6 },

    { "caption": "" },
    { "focus": "erwin", "color": "#F4AC1D", "radius": 80 },
    { "say": "erwin", "text": "El gato es la excusa. La caja es la excusa.", "duration": 3.4 },
    { "wait": 3.6 },
    { "say": "erwin", "text": "La pregunta es otra: ¿qué es real antes de que alguien lo mire?", "duration": 4.0 },
    { "wait": 4.2 },
    { "music": { "volume": 1, "duration": 3 } },
    { "caption": "Una lectura dice que la medición decide el resultado. Otra, que el mundo se divide y ocurren los dos." },
    { "wait": 4.6 },
    { "caption": "Las dos predicen lo mismo. Por eso, casi un siglo después, la pregunta sigue abierta." },
    { "wait": 4.8 }
  ]
}
