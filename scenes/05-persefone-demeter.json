    { "wait": 0.55 },
    { "do": "var g=world.props.find(function(q){return q.id==='granada';}); if(g) g.seeds=2;", "tone": 620, "dur": 0.1 },
    { "wait": 0.55 },
    { "do": "var g=world.props.find(function(q){return q.id==='granada';}); if(g) g.seeds=1;", "tone": 580, "dur": 0.1 },
    { "wait": 0.55 },
    { "do": "var g=world.props.find(function(q){return q.id==='granada';}); if(g) g.seeds=0;", "tone": 520, "dur": 0.12 },
    { "wait": 1.0 },
    { "caption": "Seis semillas. Y quien prueba el alimento del inframundo, queda ligado a él." },
    { "wait": 4.8 },
    { "camera": { "reset": true } },
    { "tween": "granada.alpha", "to": 0, "duration": 0.6 },
    { "caption": "Ningún dios podía romper aquella ley, ni siquiera Zeus." },
    { "wait": 4.0 },
    { "music": { "volume": 0.5, "duration": 2 } },
    { "caption": "Entonces hubo un pacto: parte del año con su madre, parte con Hades." },
    { "wait": 4.8 },

    { "caption": "" },
