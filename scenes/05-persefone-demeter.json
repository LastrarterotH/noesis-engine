    { "do": "world.props.filter(function(p){return p._spring;}).forEach(function(p){world.tween(p,'alpha',0,{duration:3});});" },
    { "do": "world.props=world.props.filter(function(p){return p.type!=='butterfly';});" },
    { "do": "world.props.filter(function(p){return p.type==='tree';}).forEach(function(p){world.tween(p,'alpha',0,{duration:3});}); world.props.filter(function(p){return p.type==='tree-bare';}).forEach(function(p){world.tween(p,'alpha',1,{duration:3});});" },
    { "tween": "ambient.saturation", "to": 0.15, "duration": 3.6, "easing": "easeInOutCubic" },
    { "weather": "leaves" },
    { "wait": 4.4 },
    { "caption": "Y entonces llegan el otoño y el invierno. Así gira el mundo." },
    { "weather": "snow" },
    { "tween": "ambient.darkness", "to": 0.26, "duration": 3.5 },
    { "wait": 5.0 },

    { "music": { "volume": 0.9, "duration": 2.5 } },
    { "caption": "Los griegos no conocían la inclinación del eje de la Tierra." },
    { "wait": 4.0 },
    { "caption": "Esa inclinación, no la pena de una diosa, es la causa real de las estaciones." },
    { "wait": 4.8 },
    { "caption": "Pero el mito nombró algo verdadero: la ausencia, la espera y la alegría del reencuentro." },
    { "wait": 5.4 }
