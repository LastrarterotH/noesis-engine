    { "appear": "hades", "duration": 0.9 },
    { "do": "var p=world.byId('perse'); if(p) p.lookAt='hades';" },
    { "tone": 70, "dur": 0.6 },
    { "wait": 3.4 },
    { "say": "hades", "text": "Soy el rey de un reino que nadie desea, y estoy cansado de gobernarlo solo.", "duration": 4.4 },
    { "wait": 4.6 },

    { "say": "deme", "text": "Perséfone, no.", "duration": 1.8 },
    { "mood": "deme", "value": "scared", "duration": 5 },
    { "wait": 1.6 },
    { "caption": "Las dos extienden las manos. Casi se alcanzan." },
    { "wait": 2.8 },
    { "vanish": "perse", "duration": 0.9 },
    { "vanish": "hades", "duration": 0.9 },
    { "tween": "grieta.open", "to": 0.12, "duration": 1.2 },
    { "tone": 60, "dur": 0.8 },
    { "wait": 2.2 },
    { "caption": "Solo queda una cesta y flores esparcidas." },
    { "wait": 3.4 },

    { "music": { "volume": 0.35, "duration": 2.5 } },
    { "caption": "Deméter busca a su hija por montañas, bosques y ríos. No la encuentra." },
    { "mood": "deme", "value": "sad", "duration": 30 },
    { "wait": 4.6 },
    { "caption": "Y mientras Deméter sufre, la tierra sufre con ella." },
    { "do": "world.props.filter(function(p){return p._spring;}).forEach(function(p){world.tween(p,'alpha',0,{duration:3});});" },
    { "do": "world.props=world.props.filter(function(p){return p.type!=='butterfly';});" },
    { "do": "world.props.filter(function(p){return p.type==='tree';}).forEach(function(p){world.tween(p,'alpha',0,{duration:3});}); world.props.filter(function(p){return p.type==='tree-bare';}).forEach(function(p){world.tween(p,'alpha',1,{duration:3});});" },
