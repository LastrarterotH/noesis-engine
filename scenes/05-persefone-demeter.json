    { "tween": "wf.alpha", "to": 1, "duration": 1.2, "easing": "easeOutCubic" },
    { "tone": 523, "dur": 0.2 },
    { "do": "var p=world.byId('perse'); if(p) p.lookAt={x:470,y:442};" },
    { "wait": 3.8 },
    { "walk": "perse", "to": [452, 434] },
    { "waitFor": "arrive:perse" },
    { "say": "perse", "text": "Nunca había visto una flor así.", "duration": 2.8 },
    { "wait": 2.6 },

    { "music": "stinger" },
    { "music": { "volume": 0.45, "duration": 1.5 } },
