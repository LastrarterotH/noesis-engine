    { "do": "world.config.canvas.layers.forEach(function(L){world.tween(L,'alpha',0,{duration:1.4});}); world.props.filter(function(p){return p.type==='tree'||p.type==='tree-bare';}).forEach(function(p){world.tween(p,'alpha',0,{duration:1.4});});" },
