    { "camera": { "shake": 10 } },
    { "tone": 90, "dur": 0.7 },
    { "tween": "wf.alpha", "to": 0, "duration": 0.5 },
    { "tween": "grieta.open", "to": 1, "duration": 1.4, "easing": "easeOutCubic" },
    { "wait": 1.6 },
